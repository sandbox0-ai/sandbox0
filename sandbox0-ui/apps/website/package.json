{
  "name": "@sandbox0/website",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "docs:generate:sandbox0infra-schema": "cd ../../.. && mkdir -p .cache/go-build && GOCACHE=$PWD/.cache/go-build go run ./sandbox0-ui/apps/website/scripts/generate_sandbox0infra_schema.go",
    "docs:prepare:versions": "node ./scripts/prepare_docs_versions.mjs",
    "docs:finalize:build": "node ./scripts/finalize_docs_build.mjs",
    "predev": "npm run docs:generate:sandbox0infra-schema && npm run docs:prepare:versions",
    "dev": "next dev --port 4300",
    "prebuild": "npm run docs:generate:sandbox0infra-schema && npm run docs:prepare:versions",
    "build": "next build",
    "postbuild": "npm run docs:finalize:build",
    "start": "next start --port 4300",
    "lint": "next lint"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.1.3",
    "@sandbox0/ui": "*",
    "mermaid": "^11.12.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
