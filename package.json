{
  "name": "sandbox0",
  "private": true,
  "packageManager": "npm@11.4.2",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "workspaces": [
    "apps/*",
    "components/*"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:dashboard",
    "build:shared": "npm run build:ui",
    "build:dashboard": "npm run build -w @sandbox0/dashboard",
    "build:ui": "npm run build -w @sandbox0/ui",
    "dev:dashboard": "npm run dev -w @sandbox0/dashboard",
    "lint:dashboard-core": "npm run lint -w @sandbox0/dashboard-core",
    "lint:ui": "npm run lint -w @sandbox0/ui",
    "test:dashboard-core": "npm run test -w @sandbox0/dashboard-core",
    "lint": "npm run lint:ui && npm run lint:dashboard-core && npm run lint -w @sandbox0/dashboard",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "rm -rf node_modules apps/*/node_modules components/*/node_modules"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
