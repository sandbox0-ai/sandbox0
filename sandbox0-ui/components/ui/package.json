{
  "name": "@sandbox0/ui",
  "version": "0.1.0",
  "description": "Shared Sandbox0 pixel-art design system",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": [
    "./dist/globals.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./globals.css": "./dist/globals.css"
  },
  "scripts": {
    "build": "tsc && cp src/globals.css dist/globals.css",
    "prepare": "npm run build",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandbox0-ai/sandbox0.git",
    "directory": "sandbox0-ui/components/ui"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@types/prismjs": "^1.26.5",
    "prismjs": "^1.30.0"
  }
}
