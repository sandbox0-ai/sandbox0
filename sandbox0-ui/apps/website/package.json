{
  "name": "@sandbox0/website",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 4300",
    "build": "next build",
    "start": "next start --port 4300",
    "lint": "next lint",
    "docs:examples:extract": "node ../../tools/docs-examples/cli.mjs extract --docs-dir ./src/app/docs --out-file ./tmp/docs-examples/manifest.json",
    "docs:examples:check": "npm run docs:examples:extract && node ../../tools/docs-examples/cli.mjs validate-fast --manifest ./tmp/docs-examples/manifest.json",
    "docs:examples:run": "npm run docs:examples:extract && node ../../tools/docs-examples/cli.mjs validate-run --manifest ./tmp/docs-examples/manifest.json --needs all --strict-deps true"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.1.3",
    "@sandbox0/ui": "*",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
